{
  "name": "@moonshot-ai/kimi-i18n",
  "version": "0.1.0",
  "private": true,
  "description": "Shared i18n infrastructure for Kimi Code — locale-aware t() with en/zh support",
  "license": "MIT",
  "author": "Moonshot AI",
  "homepage": "https://github.com/MoonshotAI/kimi-code/tree/main/packages/i18n#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MoonshotAI/kimi-code.git",
    "directory": "packages/i18n"
  },
  "bugs": {
    "url": "https://github.com/MoonshotAI/kimi-code/issues"
  },
  "keywords": [
    "kimi",
    "i18n",
    "internationalization",
    "locale"
  ],
  "files": [
    "dist"
  ],
  "type": "module",
  "imports": {
    "#/*": "./src/*.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  }
}