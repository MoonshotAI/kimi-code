TELEGRAM_BOT_TOKEN=your_bot_token_here
DATABASE_PATH=./data/kimigram.db
PAIRING_CODE_TTL_MINUTES=10
LOG_LEVEL=info
KIMI_SERVER_URL=http://127.0.0.1:58627
# Provide either KIMI_BEARER_TOKEN directly or a path to a token file.
KIMI_BEARER_TOKEN=
KIMI_TOKEN_FILE=~/.kimi-code/token
# WebSocket auth mode: subprotocol (default) or query.
# NOTE: query mode places the bearer token in the URL and may expose it to
# proxies or server logs. Prefer subprotocol when supported.
KIMI_WS_AUTH_MODE=subprotocol
